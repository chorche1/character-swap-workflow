# Required API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Optional — fal.ai (VEED Subtitle Styling cloud captions, ~$0.10/min).
# Sign up at https://fal.ai/dashboard/keys (no credit card required for signup).
# Without this, the `veed-*` caption templates appear locked in the Editor picker.
FAL_API_KEY=

# Optional — Higgsfield official REST API (Swap "Higgsfield Character Swap" model).
# Create a key+SECRET pair at https://cloud.higgsfield.ai/api-keys (this is the
# static API credential, NOT the CLI/MCP device-login). BOTH are required.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Model overrides (optional). Defaults shown.
# ANTHROPIC_MODEL=claude-opus-4-7
# OPENAI_IMAGE_MODEL=gpt-image-2
# GROK_VIDEO_MODEL=grok-imagine-latest

# Pipeline tuning (optional). Defaults shown.
# MAX_RETRIES=3
# IMAGE_CONCURRENCY=1
# VIDEO_POLL_INTERVAL_SECS=12
# VIDEO_TIMEOUT_SECS=600
# IMAGE_SIZE=1024x1024
