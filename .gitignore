# uv
uv.lock

# Remotion: never commit Node modules or the built preview bundle
remotion/node_modules
web/static/remotion-preview.js
web/static/remotion-preview.js.map

# generated guide artifacts (keep the .md source)
WORKFLOWS_GUIDE.pdf
WORKFLOWS_GUIDE.html
.claude/scheduled_tasks.lock

# swap-engine eval outputs (scripts/swap_eval.py)
eval_out/
